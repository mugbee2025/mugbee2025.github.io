---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getCollection } from 'astro:content';

// microCMS → astro content collection から取得
const allPosts = await getCollection('blogs');

// 全タグオブジェクトを収集して slug をキーにユニーク化
const tagMap = new Map<string, { id: string; name: string; slug: string }>();
for (const post of allPosts) {
  for (const t of post.data.tags ?? []) {
    if (!tagMap.has(t.slug)) tagMap.set(t.slug, t);
  }
}
const uniqueTags = Array.from(tagMap.values());
---

<BaseLayout pageTitle="タグ一覧">
  <Header />

  <ul>
    {
      uniqueTags.map((tag) => (
        <li>
          <a href={`/tags/${tag.slug}`}>{tag.name}</a>
        </li>
      ))
    }
  </ul>

  <Footer />
</BaseLayout>
