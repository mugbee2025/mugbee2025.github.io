---
const { title, description, noindex = false } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);

const gtmHeadCode = `<script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src='https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);})(window,document,'script','dataLayer','GTM-KHQMJQW6');</script>`;
---

<div set:html={gtmHeadCode} />

<!-- Global Metadata -->
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<link rel="sitemap" href="/sitemap-index.xml" />
<meta name="generator" content={Astro.generator} />

<!-- Canonical URL -->
<link rel="canonical" href={canonicalURL} />

<!-- noindex を使う場合 -->
{noindex && <meta name="robots" content="noindex, nofollow" />}

<!-- Primary Meta Tags -->
<title>{title ?? 'ゆるーりサモンズボード攻略ブログ'}</title>
<meta name="title" content={title ?? 'ゆるーりサモンズボード攻略ブログ'} />
<meta
  name="description"
  content={description ?? 'スマホゲーム「サモンズボード」の攻略ブログです。'}
/>

<!-- Open Graph / Facebook -->
<meta property="og:type" content="website" />
<meta property="og:url" content={Astro.url} />
<meta property="og:title" content="ゆるーりサモンズボード攻略ブログ" />
<meta
  property="og:description"
  content="スマホゲーム「サモンズボード」の攻略ブログです。"
/>

<!-- Twitter -->
<meta property="twitter:card" content="summary_large_image" />
<meta property="twitter:url" content={Astro.url} />
<meta property="twitter:title" content="ゆるーりサモンズボード攻略ブログ" />
<meta
  property="twitter:description"
  content="スマホゲーム「サモンズボード」の攻略ブログです。"
/>
